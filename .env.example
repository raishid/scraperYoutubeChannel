# Clave de autenticacion hacia tu API externa (no subir el valor real a git)
APP_KEY=base64:REEMPLAZAR_CON_TU_APP_KEY

# URL base del backend que provee cuentas/cookies
API_URL=https://api.tu-dominio.com/api

# Puerto interno/publicado por Docker (Dokploy suele mapear automaticamente)
APP_PORT=5000

# Gunicorn (valores recomendados iniciales para produccion)
# 1 vCPU: workers=2, 2 vCPU: workers=3-4
GUNICORN_WORKERS=2
GUNICORN_THREADS=2

# Timeout para requests lentas (scraping puede tardar)
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=120
GUNICORN_KEEPALIVE=5

# Nivel de logs: debug, info, warning, error
GUNICORN_LOG_LEVEL=info

# Vacio = usa el worker por defecto configurado en gunicorn_conf.py
# Si quieres forzarlo: geventwebsocket.gunicorn.workers.GeventWebSocketWorker
GUNICORN_WORKER_CLASS=